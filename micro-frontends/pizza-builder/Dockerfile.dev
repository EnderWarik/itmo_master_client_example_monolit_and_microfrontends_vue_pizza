FROM node:20

WORKDIR /app

# Copy package files
COPY pizza-builder/package.json ./

# Install dependencies
RUN npm cache clean --force && rm -f package-lock.json && npm install

# Copy @pizza packages
COPY packages/shared /app/node_modules/@pizza/shared

# Copy source files
COPY pizza-builder/ .

EXPOSE 5002

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
