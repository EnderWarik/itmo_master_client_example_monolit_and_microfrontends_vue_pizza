FROM node:20

WORKDIR /app

# Copy package files (exclude package-lock.json to avoid Rollup arm64 issues)
COPY profile/package.json ./
COPY profile/.npmrc ./

# Install dependencies fresh (fixes @rollup/rollup-linux-arm64-gnu issue)
RUN npm install

# Copy @pizza packages (copy src/ content to match import paths)
COPY packages/shared/src /app/node_modules/@pizza/shared

# Copy source files
COPY profile/ .

EXPOSE 5004

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
